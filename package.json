{
  "name": "create-wiki-llm",
  "version": "0.0.0",
  "description": "Scaffold a Karpathy-style LLM knowledge-base repo for Claude Code, driven by kb-* skills.",
  "type": "module",
  "bin": {
    "create-wiki-llm": "./src/cli.mjs"
  },
  "files": [
    "src/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test test/customization-check.test.mjs test/manifest.test.mjs test/path-safety.test.mjs test/template.test.mjs",
    "fixtures:update": "node scripts/build-fixtures.mjs",
    "build-manifest": "node scripts/build-manifest.mjs",
    "check-manifest": "node scripts/build-manifest.mjs && git diff --exit-code templates/manifest.json",
    "prepublishOnly": "echo \"prepublishOnly not implemented yet\" && exit 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MLMario/wiki-llm.git"
  },
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {}
}
